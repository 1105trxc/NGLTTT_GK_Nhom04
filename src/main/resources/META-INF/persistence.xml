<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<persistence version="3.0" xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd">

    <persistence-unit name="LanguageCenterPU" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        
        <!-- Các Entities sẽ được tự động scan hoặc khai báo ở đây -->
        <!-- <class>vn.edu.ute.languagecenter.entities.Course</class> -->
        <!-- <class>vn.edu.ute.languagecenter.entities.ClassEntity</class> -->
        <!-- <class>vn.edu.ute.languagecenter.entities.Room</class> -->
        <!-- ... -->

        <properties>
            <!-- Thông tin kết nối MySQL -->
            <property name="jakarta.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:mysql://localhost:3306/mis_language_center?useSSL=false&amp;serverTimezone=UTC&amp;allowPublicKeyRetrieval=true"/>
            <property name="jakarta.persistence.jdbc.user" value="root"/>
            <property name="jakarta.persistence.jdbc.password" value="123456"/> <!-- Thay đổi password tương ứng trên máy tính -->

            <!-- Hibernate Properties -->
            <!-- dialect phù hợp cho phiên bản MySQL -->
            <property name="hibernate.dialect" value="org.hibernate.dialect.MySQLDialect"/>
            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <!-- Hiển thị câu SQL trên console -->
            <property name="hibernate.show_sql" value="true"/>
            <property name="hibernate.format_sql" value="true"/>
        </properties>
    </persistence-unit>
</persistence>
